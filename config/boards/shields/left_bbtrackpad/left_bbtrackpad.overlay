/ {
    chosen {
        zmk,trackpad_led = &trackpad_led;
    };
    trackpad_led: pwmledo{
        compatible = "pwm-leds";
        pwm_led_0 {
            pwms = <&pwm1 0 PWM_USEC(20) PWM_POLARITY_NORMAL>;
        };
    };
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <16>;
        rows = <6>;
        map = <
RC(0,0)  RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)  RC(6,6)             RC(6,14)           RC(0,8)  RC(0,9)  RC(0,10) RC(0,11) RC(0,12) RC(0,13)
RC(1,0)  RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)                                         RC(1,8)  RC(1,9)  RC(1,10) RC(1,11) RC(1,12) RC(1,13)
RC(2,0)  RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)  RC(6,7)             RC(6,15)           RC(2,8)  RC(2,9)  RC(2,10) RC(2,11) RC(2,12) RC(2,13)
RC(3,0)  RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)  RC(5,7)  RC(5,6)    RC(5,15) RC(5,14)  RC(3,8)  RC(3,9)  RC(3,10) RC(3,11) RC(3,12) RC(3,13)
         RC(4,1) RC(4,2) RC(4,3) RC(4,4) RC(4,5)                                         RC(4,8)  RC(4,9)  RC(4,10) RC(4,11) RC(4,12)
        >;
    };
};

&pwm1 {
    status = "okay";
    pinctrl-0 = <&pwm1_default>;
    pinctrl-1 = <&pwm1_sleep>;
    pinctrl-names = "default", "sleep";
};


&i2c0 {
    status = "okay";
    compatible = "nordic,nrf-twim";
    clock-frequency = <I2C_BITRATE_FAST>; 
    pinctrl-0 = <&i2c0_default>;
    pinctrl-1 = <&i2c0_sleep>;
    pinctrl-names = "default", "sleep";

    bbtrackpad3B:a320@3B {
        compatible = "avago,a320";
        reg = <0x3B>;
        status = "okay";
    };
    bbtrackpad37:a320@37 {
        compatible = "avago,a320";
        reg = <0x37>;
        status = "okay";
    };
    
};


/ {
    bbtrackpad_inputs {
        #address-cells = <1>;
        #size-cells = <0>;

    };
    bbtrackpad3B_listener: bbtrackpad3B_listener {
        compatible = "zmk,input-listener";
        status = "disabled";
        device = <&bbtrackpad3B>;
    };
    bbtrackpad37_listener: bbtrackpad37_listener {
        compatible = "zmk,input-listener";
        status = "disabled";
        device = <&bbtrackpad37>;
    };
};

&bbtrackpad3B_listener {
    status = "okay";
};

 
&bbtrackpad37_listener {
    status = "okay";
};

&pinctrl {
    pwm1_default:pwm1_default{
        group1{
            psels = <NRF_PSEL(PWM_OUT0, 0, 7)>; // Backlight for Trackball
        };
    };

    pwm1_sleep: pwm1_sleep {
        group1 {
            psels = <NRF_PSEL(PWM_OUT0, 0, 7)>;
            bias-pull-down;
        };
    };

    i2c0_default: i2c0_default {
        group1 {
            psels = <NRF_PSEL(TWIM_SDA, 1, 9)>,
                <NRF_PSEL(TWIM_SCL, 0, 12)>;
        };
    };

    i2c0_sleep: i2c0_sleep {
        group1 {
            psels = <NRF_PSEL(TWIM_SDA, 1, 9)>,
                <NRF_PSEL(TWIM_SCL, 0, 12)>;
            low-power-enable;
        };
    };
};


